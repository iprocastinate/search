# TELEGRAM BOT CONFIGURATION
API_ID=123456
API_HASH=your_api_hash_here
BOT_TOKEN=your_bot_token_here
OWNER_ID=123456789

# CHANNEL CONFIGURATIONS
# The Storage Channel stores the original post with the channel link as button.
# Must start with -100 for supergroups/channels.
STORAGE_CHANNEL_ID=-1000000000000

# The Request Channel logs requests when search returns no results.
# Must start with -100 for supergroups/channels.
REQUEST_CHANNEL_ID=-1000000000000

# DATABASE CONFIGURATION
# MongoDB Connection string (e.g. mongodb://localhost:27017 or MongoDB Atlas URI)
MONGO_URI=mongodb://localhost:27017/telegram_index_bot
